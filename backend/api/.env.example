# SmartHealth backend — environment template.
# Copy to `.env` (same directory) and fill in real values. `.env` is gitignored.

# ── App ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=dev-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database / cache ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://smarthealth:smarthealth@localhost:5432/smarthealth
REDIS_URL=redis://localhost:6379/0

# ── data.gov.in (real Indian public-health open data) ────────────────────────
# Sample key returns max 10 records. Get your own at https://data.gov.in → My Account.
DATA_GOV_API_KEY=579b464db66ec23bdd000001cdd3946e44ce4aad7209ff7b23ac571b
DATA_GOV_BASE_URL=https://api.data.gov.in/resource
DATA_GOV_STATE_BEDS_RESOURCE_ID=d133eac1-143f-4c1d-bdc4-b9dfd73ab78c

# ── LLM ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── WhatsApp Cloud API ───────────────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=default_verify_token
